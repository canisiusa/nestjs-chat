{
  "name": "nestjs-chat",
  "version": "0.1.1",
  "description": "Production-ready real-time chat SDK for NestJS — ChatModule.forRoot() with Prisma, PostgreSQL, Socket.IO, BullMQ, Redis.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "author": "canisius ADOGNON",
  "homepage": "https://canisiusa.github.io/nestjs-chat/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canisiusa/nestjs-chat.git"
  },
  "bugs": {
    "url": "https://github.com/canisiusa/nestjs-chat/issues"
  },
  "keywords": [
    "nestjs",
    "chat",
    "realtime",
    "socket.io",
    "websocket",
    "messaging",
    "prisma",
    "postgresql",
    "bullmq",
    "redis",
    "multi-tenant",
    "sdk"
  ],
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo",
    "bin",
    "prisma/schema.prisma",
    "prisma/migrations",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "chat-migrate": "bin/migrate.js"
  },
  "scripts": {
    "prebuild": "prisma generate",
    "build": "nest build",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "test:e2e": "node test/e2e/run.mjs && node test/e2e/run-extended.mjs && node test/e2e/run-hardening.mjs && sleep 65 && node test/e2e/run-concurrency.mjs",
    "test:e2e:golden": "node test/e2e/run.mjs",
    "test:e2e:extended": "node test/e2e/run-extended.mjs",
    "test:e2e:hardening": "node test/e2e/run-hardening.mjs",
    "test:e2e:concurrency": "node test/e2e/run-concurrency.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "dependencies": {
    "@nestjs/config": "^3.3.0",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/websockets": "^10.4.15",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.76.0",
    "ioredis": "^5.4.2",
    "nest-winston": "^1.10.2",
    "pg": "^8.20.0",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0",
    "winston": "^3.19.0",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.4.0",
    "socket.io-client": "^4.8.0",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "typescript-eslint": "^8.20.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/generated/",
      "/dist/",
      ".*\\.module\\.ts$",
      ".*/testing/.*"
    ]
  }
}
